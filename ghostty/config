# Ghostty — terminal layer of terminal-stack
# Installs to ~/.config/ghostty/config · syntax: key = value (repeated keys accumulate)
# Reference + rationale for every key: ./README.md · upstream: https://ghostty.org/docs/config

# ── font ──────────────────────────────────────────────────────────────
# Dank Mono is primary; Symbols Nerd Font Mono is a fallback so LazyVim /
# Starship glyphs render — Dank Mono carries no Nerd-Font icons of its own.
font-family = "Dank Mono"
font-family = "Symbols Nerd Font Mono"
font-size = 18
# Thicken strokes on macOS — Dank Mono's thin glyphs (esp. Cyrillic) render
# grainy at native weight; thickening restores solid, legible edges.
font-thicken = true

# ── theme ─────────────────────────────────────────────────────────────
# Catppuccin ships bundled with Ghostty; the stack reuses Mocha across
# Zellij / LazyVim / Starship for one palette. Latte is its light sibling,
# auto-selected to follow the macOS appearance. Verify: ghostty +list-themes
theme = light:Catppuccin Latte,dark:Catppuccin Mocha

# ── window ────────────────────────────────────────────────────────────
# Opaque by choice (readability over glass). To enable translucency add
# `background-opacity = 0.95` + `background-blur = true` — see README.
window-padding-x = 8
window-padding-y = 8

# ── macOS ─────────────────────────────────────────────────────────────
# Send Alt on Option so Alt-binds in nvim/zsh fire, instead of composing
# accented characters.
macos-option-as-alt = true

# ── keybinds — TERMINAL LAYER ONLY ────────────────────────────────────
# Invariant: Ghostty binds only terminal-scoped actions, never a multiplexer
# or editor key. Leave ctrl-combos free so they reach the layers below —
# Zellij is modal (Ctrl+p/t/n/s/o…) and nvim's leader is <space>.
# (@.claude/rules/config.md — keyboard-layer contract)
keybind = cmd+shift+r=reload_config
keybind = global:cmd+backquote=toggle_quick_terminal
