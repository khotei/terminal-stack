// Zellij — multiplexer layer of terminal-stack
// Installs to ~/.config/zellij/config.kdl
// Reference + keybinding cheatsheet: ./README.md · upstream: https://zellij.dev/documentation
// Validate: `zellij --config zellij/config.kdl setup --check` (run by /check + CI)

// ── options ───────────────────────────────────────────────────────────
theme "catppuccin-mocha"        // fallback if the terminal reports no appearance
// Auto-switch with the OS: Ghostty follows macOS appearance and reports it via
// CSI 2031 / DSR 997; Zellij picks theme_dark/theme_light accordingly. Both
// palettes are defined in the themes block below (self-contained).
theme_dark "catppuccin-mocha"
theme_light "catppuccin-latte"
default_layout "compact"        // built-in compact-bar — theme-aware, shows mode + keys + tabs
pane_frames true                // on so the rounded corners below can draw; frame = 1-cell content breathing room
copy_on_select true             // select = copy, tmux-like
scrollback_editor "nvim"        // `Edit scrollback` opens in the stack's editor
mouse_mode true

// ── UI ────────────────────────────────────────────────────────────────
ui {
    pane_frames {
        rounded_corners true    // inert unless pane_frames true above
    }
}

// ── keybinds: native modal, manual lock ───────────────────────────────
// Native modal Zellij (Ctrl+p pane · Ctrl+t tab · Ctrl+n resize · Ctrl+s
// scroll · Ctrl+o session · …), no tmux prefix. Nested apps do NOT auto-lock —
// you hold the lock yourself, by choice (no zellij-autolock plugin):
//   · Alt+d toggles Locked ⇄ Normal — the single manual switch. In Locked,
//     Zellij hands the pane every key, so nvim's Ctrl+n/p and Claude Code's
//     Ctrl+o/t/r reach the app instead of a Zellij mode; Alt+d again takes the
//     multiplexer back. Home-row + Option, one left hand. GOTCHA: enter nvim /
//     claude and their Ctrl-keys are eaten until you Alt+d — no auto-locking.
//   · unbind Ctrl+g — Locked mode's default unlock; freed so Claude Code's own
//     Ctrl+g (edit prompt in $EDITOR) reaches it. Leave Locked with Alt+d.
// Locked mode honours only Alt+d, so a way back out is always bound.
keybinds {
    shared_except "locked" {
        unbind "Ctrl g"
        bind "Alt d" { SwitchToMode "Locked"; }
    }
    locked {
        unbind "Ctrl g"
        bind "Alt d" { SwitchToMode "Normal"; }
    }
    // choose-tree (Ctrl+o f) — tmux `choose-tree` analog: a fuzzy tree of
    // sessions→tabs→panes where 1-9/A-Z jump straight to one. Picked over the
    // built-in session-manager (Ctrl+o w), which can't drill to pane level. The wasm
    // is fetched into plugins/ by install.sh (git-ignored, best-effort — Ctrl+o f is a
    // no-op if absent). floating+move_to_focused_tab mirror the session-manager bind.
    // https://github.com/laperlej/zellij-choose-tree
    session {
        bind "f" {
            LaunchOrFocusPlugin "file:~/.config/zellij/plugins/zellij-choose-tree.wasm" {
                floating true
                move_to_focused_tab true
            }
            SwitchToMode "Normal"
        }
    }
}

// ── themes: dark + light (Catppuccin, component spec) ─────────────────
// Verbatim from Zellij's upstream Catppuccin assets — the COMPONENT format, not
// the 10-colour palette. Only components can theme the pane frames; with a palette
// present Zellij ignores component overrides and derives frames from it, so palette
// form gives no frame control at all.
// github.com/zellij-org/zellij/tree/main/zellij-utils/assets/themes
//
// Local change per theme: both frame bases. Rule — the FOCUSED frame takes the
// strongest contrast to the background (near-black on light, near-white on dark),
// the IDLE frame nearly dissolves into it. Upstream paints focus the accent green
// and omits frame_unselected (idle falls back to fg); we split them hard so which
// pane holds focus is unmistakable in either appearance.
themes {
    catppuccin-mocha {
        text_unselected {
            base 205 214 244
            background 24 24 37
            emphasis_0 250 179 135
            emphasis_1 137 220 235
            emphasis_2 166 227 161
            emphasis_3 245 194 231
        }
        text_selected {
            base 205 214 244
            background 88 91 112
            emphasis_0 250 179 135
            emphasis_1 137 220 235
            emphasis_2 166 227 161
            emphasis_3 245 194 231
        }
        ribbon_selected {
            base 24 24 37
            background 166 227 161
            emphasis_0 243 139 168
            emphasis_1 250 179 135
            emphasis_2 245 194 231
            emphasis_3 137 180 250
        }
        ribbon_unselected {
            base 24 24 37
            background 205 214 244
            emphasis_0 243 139 168
            emphasis_1 205 214 244
            emphasis_2 137 180 250
            emphasis_3 245 194 231
        }
        table_title {
            base 166 227 161
            background 0
            emphasis_0 250 179 135
            emphasis_1 137 220 235
            emphasis_2 166 227 161
            emphasis_3 245 194 231
        }
        table_cell_selected {
            base 205 214 244
            background 88 91 112
            emphasis_0 250 179 135
            emphasis_1 137 220 235
            emphasis_2 166 227 161
            emphasis_3 245 194 231
        }
        table_cell_unselected {
            base 205 214 244
            background 24 24 37
            emphasis_0 250 179 135
            emphasis_1 137 220 235
            emphasis_2 166 227 161
            emphasis_3 245 194 231
        }
        list_selected {
            base 205 214 244
            background 88 91 112
            emphasis_0 250 179 135
            emphasis_1 137 220 235
            emphasis_2 166 227 161
            emphasis_3 245 194 231
        }
        list_unselected {
            base 205 214 244
            background 24 24 37
            emphasis_0 250 179 135
            emphasis_1 137 220 235
            emphasis_2 166 227 161
            emphasis_3 245 194 231
        }
        frame_selected {
            base 205 214 244       // Text — near-white: focus takes max contrast on dark
            background 0
            emphasis_0 250 179 135
            emphasis_1 137 220 235
            emphasis_2 245 194 231
            emphasis_3 0
        }
        frame_unselected {
            base 49 50 68          // Surface0 — idle frame nearly dissolves into the bg
            background 0
            emphasis_0 250 179 135
            emphasis_1 137 220 235
            emphasis_2 245 194 231
            emphasis_3 0
        }
        frame_highlight {
            base 250 179 135
            background 0
            emphasis_0 245 194 231
            emphasis_1 250 179 135
            emphasis_2 250 179 135
            emphasis_3 250 179 135
        }
        exit_code_success {
            base 166 227 161
            background 0
            emphasis_0 137 220 235
            emphasis_1 24 24 37
            emphasis_2 245 194 231
            emphasis_3 137 180 250
        }
        exit_code_error {
            base 243 139 168
            background 0
            emphasis_0 249 226 175
            emphasis_1 0
            emphasis_2 0
            emphasis_3 0
        }
        multiplayer_user_colors {
            player_1 245 194 231
            player_2 137 180 250
            player_3 0
            player_4 249 226 175
            player_5 137 220 235
            player_6 0
            player_7 243 139 168
            player_8 0
            player_9 0
            player_10 0
        }
    }
    catppuccin-latte {
        text_unselected {
            base 76 79 105
            background 220 224 232
            emphasis_0 254 100 11
            emphasis_1 4 165 229
            emphasis_2 64 160 43
            emphasis_3 210 15 57
        }
        text_selected {
            base 76 79 105
            background 172 176 190
            emphasis_0 254 100 11
            emphasis_1 4 165 229
            emphasis_2 64 160 43
            emphasis_3 234 118 203
        }
        ribbon_selected {
            base 220 224 232
            background 64 160 43
            emphasis_0 210 15 57
            emphasis_1 254 100 11
            emphasis_2 234 118 203
            emphasis_3 30 102 245
        }
        ribbon_unselected {
            base 220 224 232
            background 92 95 119
            emphasis_0 234 118 203
            emphasis_1 76 79 105
            emphasis_2 30 102 245
            emphasis_3 234 118 203
        }
        table_title {
            base 64 160 43
            background 0
            emphasis_0 254 100 11
            emphasis_1 4 165 229
            emphasis_2 64 160 43
            emphasis_3 234 118 203
        }
        table_cell_selected {
            base 76 79 105
            background 172 176 190
            emphasis_0 254 100 11
            emphasis_1 4 165 229
            emphasis_2 64 160 43
            emphasis_3 234 118 203
        }
        table_cell_unselected {
            base 76 79 105
            background 220 224 232
            emphasis_0 254 100 11
            emphasis_1 4 165 229
            emphasis_2 64 160 43
            emphasis_3 234 118 203
        }
        list_selected {
            base 76 79 105
            background 172 176 190
            emphasis_0 254 100 11
            emphasis_1 4 165 229
            emphasis_2 64 160 43
            emphasis_3 234 118 203
        }
        list_unselected {
            base 76 79 105
            background 220 224 232
            emphasis_0 254 100 11
            emphasis_1 4 165 229
            emphasis_2 64 160 43
            emphasis_3 234 118 203
        }
        frame_selected {
            base 76 79 105         // Text — near-black: focus takes max contrast on light
            background 0
            emphasis_0 254 100 11
            emphasis_1 4 165 229
            emphasis_2 234 118 203
            emphasis_3 0
        }
        frame_unselected {
            base 204 208 218       // Surface0 — idle frame nearly dissolves into the bg
            background 0
            emphasis_0 254 100 11
            emphasis_1 4 165 229
            emphasis_2 234 118 203
            emphasis_3 0
        }
        frame_highlight {
            base 254 100 11
            background 0
            emphasis_0 210 15 57
            emphasis_1 136 57 239
            emphasis_2 254 100 11
            emphasis_3 254 100 11
        }
        exit_code_success {
            base 64 160 43
            background 0
            emphasis_0 4 165 229
            emphasis_1 220 224 232
            emphasis_2 234 118 203
            emphasis_3 30 102 245
        }
        exit_code_error {
            base 210 15 57
            background 0
            emphasis_0 223 142 29
            emphasis_1 0
            emphasis_2 0
            emphasis_3 0
        }
        multiplayer_user_colors {
            player_1 234 118 203
            player_2 30 102 245
            player_3 0
            player_4 223 142 29
            player_5 4 165 229
            player_6 0
            player_7 210 15 57
            player_8 0
            player_9 0
            player_10 0
        }
    }
}
