// Zellij — multiplexer layer of terminal-stack
// Installs to ~/.config/zellij/config.kdl
// Reference + keybinding cheatsheet: ./README.md · upstream: https://zellij.dev/documentation
// Validate: `zellij --config zellij/config.kdl setup --check` (run by /check + CI)

// ── options ───────────────────────────────────────────────────────────
theme "gruvbox-material-dark"   // fallback if the terminal reports no appearance
// Auto-switch with the OS: Ghostty follows macOS appearance and reports it via
// CSI 2031 / DSR 997; Zellij picks theme_dark/theme_light accordingly. Both
// palettes are defined in the themes block below (self-contained).
theme_dark "gruvbox-material-dark"
theme_light "gruvbox-material-light"
default_layout "compact"        // built-in compact-bar — theme-aware, shows mode + keys + tabs
pane_frames true                // on so the rounded corners below can draw; frame = 1-cell content breathing room
copy_on_select true             // select = copy, tmux-like
scrollback_editor "nvim"        // `Edit scrollback` opens in the stack's editor
mouse_mode true

// ── UI ────────────────────────────────────────────────────────────────
ui {
    pane_frames {
        rounded_corners true    // inert unless pane_frames true above
    }
}

// ── keybinds: native modal, manual lock ───────────────────────────────
// Native modal Zellij (Ctrl+p pane · Ctrl+t tab · Ctrl+n resize · Ctrl+s
// scroll · Ctrl+o session · …), no tmux prefix. Nested apps do NOT auto-lock —
// you hold the lock yourself, by choice (no zellij-autolock plugin):
//   · Alt+d toggles Locked ⇄ Normal — the single manual switch. In Locked,
//     Zellij hands the pane every key, so nvim's Ctrl+n/p and Claude Code's
//     Ctrl+o/t/r reach the app instead of a Zellij mode; Alt+d again takes the
//     multiplexer back. Home-row + Option, one left hand. GOTCHA: enter nvim /
//     claude and their Ctrl-keys are eaten until you Alt+d — no auto-locking.
//   · unbind Ctrl+g — Locked mode's default unlock; freed so Claude Code's own
//     Ctrl+g (edit prompt in $EDITOR) reaches it. Leave Locked with Alt+d.
// Locked mode honours only Alt+d, so a way back out is always bound.
keybinds {
    shared_except "locked" {
        unbind "Ctrl g"
        bind "Alt d" { SwitchToMode "Locked"; }
    }
    locked {
        unbind "Ctrl g"
        bind "Alt d" { SwitchToMode "Normal"; }
    }
    // choose-tree (Ctrl+o f) — tmux `choose-tree` analog: a fuzzy tree of
    // sessions→tabs→panes where 1-9/A-Z jump straight to one. Picked over the
    // built-in session-manager (Ctrl+o w), which can't drill to pane level. The wasm
    // is fetched into plugins/ by install.sh (git-ignored, best-effort — Ctrl+o f is a
    // no-op if absent). floating+move_to_focused_tab mirror the session-manager bind.
    // https://github.com/laperlej/zellij-choose-tree
    session {
        bind "f" {
            LaunchOrFocusPlugin "file:~/.config/zellij/plugins/zellij-choose-tree.wasm" {
                floating true
                move_to_focused_tab true
            }
            SwitchToMode "Normal"
        }
    }
}

// ── themes: dark + light (names below) ────────────────────────────────
// ANSI colours lifted verbatim from Ghostty's active bundled theme, so the
// terminal and the multiplexer render one identical palette. bg is a *lifted*
// background tone (not the darkest) so pane frames stay visible against the base
// — that legibility, not any one palette, is why these are hand-mapped here.
themes {
    gruvbox-material-dark {
        bg "#504945"      // bg4 — lifted so pane frames read against bg0
        fg "#d4be98"      // fg0
        red "#ea6962"
        green "#a9b665"
        blue "#7daea3"
        yellow "#d8a657"
        magenta "#d3869b"
        orange "#e78a4e"
        cyan "#89b482"    // aqua
        black "#282828"   // bg0
        white "#d4be98"   // fg0
    }
    gruvbox-material-light {
        bg "#d5c4a1"      // bg2 — lifted so frames read against the light base
        fg "#654735"      // fg0
        red "#c14a4a"
        green "#6c782e"
        blue "#45707a"
        yellow "#b47109"
        magenta "#945e80"
        orange "#c35e0a"
        cyan "#4c7a5d"    // aqua
        black "#fbf1c7"   // bg0 (lightest)
        white "#654735"   // fg0
    }
}
