{
  // Editor + `tsc --noEmit` only — Bun runs the .ts files directly, no build step.
  // Options mirror `bun init`'s recommended defaults (bun.com/docs/runtime/typescript).
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "types": ["bun"]
  },
  "include": ["scripts/**/*.ts"]
}
