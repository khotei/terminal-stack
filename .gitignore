# ── OS noise ────────────────────────────────────────────────
.DS_Store
.AppleDouble
*.swp
*~

# ── Claude Code (machine-local, never committed) ────────────
.claude/settings.local.json
.claude/sessions/
.claude/shell-snapshots/
.claude/telemetry/
.claude/.last-cleanup

# ── Zellij plugin binaries (fetched by install.sh) ─────────
zellij/plugins/*.wasm

# ── Neovim / LazyVim generated state ────────────────────────
nvim/lazy-lock.json.bak
nvim/.luarc.json
nvim/spell/

# ── Bun / TypeScript (scripts are RUN, not built; deps are dev-only) ────
node_modules/
*.tsbuildinfo

# ── Secrets / local overrides ───────────────────────────────
*.local
.env
zsh/.zshrc.local
