# ── OS noise ────────────────────────────────────────────────
.DS_Store
.AppleDouble
*.swp
*~

# ── Claude Code (machine-local, never committed) ────────────
.claude/settings.local.json
.claude/sessions/
.claude/shell-snapshots/
.claude/telemetry/
.claude/.last-cleanup
.claude/worktrees/

# ── Zellij plugin binaries (fetched by install.sh) ─────────
zellij/plugins/*.wasm
# Zellij's Configuration UI rewrites config.kdl as a full dump and drops a .bak — never ours
zellij/*.bak

# ── Neovim / LazyVim generated state ────────────────────────
nvim/lazy-lock.json.bak
nvim/.luarc.json
nvim/spell/

# ── Secrets / local overrides ───────────────────────────────
*.local
.env
zsh/.zshrc.local
