# terminal-stack git config (~/.config/git/config) — additive; your identity in
# ~/.gitconfig is untouched. Needs git-delta (Brewfile).

[core]
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true       # n / N jump between diff hunks in the pager
	line-numbers = true

[merge]
	conflictStyle = zdiff3

[diff]
	colorMoved = default
	# delta (above) only pages unified diffs; `git difftool` needs its own tool.
	# nvim ships with the stack, so no Xcode/opendiff fallback. lazygit's
	# "open external diff" runs git difftool → this.
	tool = nvimdiff

[difftool]
	prompt = false

[init]
	defaultBranch = main

[push]
	autoSetupRemote = true

[pull]
	ff = only
